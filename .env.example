# These variables are public because they are compiled into the static JavaScript bundle.
VITE_BRIDGE_ENV=mainnet

# Recommended for production. Supply one or more browser-compatible Base RPC URLs.
# Separate fallback URLs with commas. The connected Base wallet is tried first when available.
# VITE_BASE_RPC_URLS=https://your-primary-base-rpc.example,https://your-backup-base-rpc.example

# The old single-URL variable is still supported.
# VITE_BASE_RPC_URL=https://your-base-rpc.example

# Optional Solana RPC override.
# VITE_SOLANA_RPC_URL=https://your-solana-rpc.example
